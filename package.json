  "repository": {
    "type": "git",
    "url": "git+https://github.com/weixiao0297/tesla-service.git"
  },
  "homepage": "https://github.com/weixiao0297/tesla-service#readme",
  "bugs": {
    "url": "https://github.com/weixiao0297/tesla-service/issues"
  },
  "keywords": [
    "tesla",
    "teslamate",
    "grafana",
    "mqtt",
    "cli"
