{
  "name": "tesla-cli2",
  "type": "module",
  "bin": {
    "tesla": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "build:cli": "tsc",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "collect": "tsx scripts/collect-data.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run test:run && npm run build"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "configstore": "^7.1.0",
    "got": "^14.6.6",
    "mqtt": "^5.15.0",
    "puppeteer": "^24.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0",
    "recharts": "^2.15.1",
    "serve-handler": "^6.1.6",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/serve-handler": "^6.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "version": "1.0.0",
  "description": "Tesla CLI for TeslaMate / Grafana data query, screenshots, and MQTT service management",
